#!/usr/bin/env bash
set -euo pipefail

PACKAGE_SPEC="${CINTARA_LANGGRAPH_PACKAGE_SPEC:-cintara-langgraph[langgraph] @ git+https://github.com/Cintaraio/cintara-langgraph.git}"

python_is_compatible() {
  local executable="$1"
  command -v "$executable" >/dev/null 2>&1 &&
    "$executable" -c 'import sys; raise SystemExit(0 if sys.version_info >= (3, 11) else 1)' >/dev/null 2>&1
}

if [ -n "${PYTHON:-}" ]; then
  PYTHON_BIN="$PYTHON"
  if ! python_is_compatible "$PYTHON_BIN"; then
    echo "The Python executable passed with PYTHON must be Python 3.11+." >&2
    exit 1
  fi
else
  PYTHON_BIN=""
  for candidate in python3.13 python3.12 python3.11 python3 python; do
    if python_is_compatible "$candidate"; then
      PYTHON_BIN="$candidate"
      break
    fi
  done

  if [ -z "$PYTHON_BIN" ]; then
    echo "Python 3.11+ is required. Install Python 3.11+ and re-run this command." >&2
    exit 1
  fi
fi

if [ -z "${VIRTUAL_ENV:-}" ]; then
  if [ ! -d ".venv" ]; then
    "$PYTHON_BIN" -m venv .venv
  fi
  # shellcheck disable=SC1091
  . .venv/bin/activate
fi

python -m pip --disable-pip-version-check install "$PACKAGE_SPEC"

echo
echo "Setting up Cintara LangGraph..."

if [ -t 0 ]; then
  python -m cintara_langgraph init "$@"
elif [ -r /dev/tty ] && { true < /dev/tty; } 2>/dev/null; then
  python -m cintara_langgraph init "$@" < /dev/tty
else
  python -m cintara_langgraph init "$@"
fi
